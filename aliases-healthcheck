
# ---- Raspberry Pi Health Checks ----

alias healthcheck.netdata='systemctl is-active netdata && ss -tulpn | grep 19999'
alias healthcheck.tailscale='tailscale status'
alias healthcheck.watchdog='systemctl is-active watchdog'
alias healthcheck.ssh='systemctl is-active ssh'
alias healthcheck.network='ip a && ping -c2 1.1.1.1'
alias healthcheck.disk='df -h /'
alias healthcheck.memory='free -h'
alias healthcheck.cpu='uptime && top -bn1 | head -n5'
alias healthcheck.temp='vcgencmd measure_temp'
alias healthcheck.throttle='vcgencmd get_throttled'
alias healthcheck.services='systemctl --failed'
alias healthcheck.logs='journalctl -p 3 -xb | tail'
alias healthcheck.nvme='sudo nvme smart-log /dev/nvme0'
alias healthcheck.netdata.web='curl -I http://localhost:19999'
alias healthcheck.tailscale.ip='tailscale ip -4'
alias healthcheck.tailscale.ping='tailscale ping pi5.warg-torino.ts.net'
alias healthcheck.ports='ss -tulpn'
alias healthcheck.load='cat /proc/loadavg'
alias healthcheck.uptime='uptime -p'
alias healthcheck.kernel='uname -a'
