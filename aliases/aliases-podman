alias pod.ydb.vista.run='podman run -d \
                  -p 2222:22 -p 1338:1338 -p 8089:8089 -p 9430:9430 \
                  --name=octo-vehu \
                  download.yottadb.com/yottadb/octo-vehu:latest-master'
                  
alias pod.ydb.vista.gui='echo "login: admin/admin"; open http://localhost:8089'

